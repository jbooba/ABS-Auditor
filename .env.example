# Core service settings
PORT=8080
ABS_POLL_SECONDS=15
ABS_PREGAME_POLL_SECONDS=120
ABS_ACTIVATION_LEAD_MINUTES=30
ABS_LOOKAHEAD_DAYS=7
ABS_OFFSEASON_SLEEP_SECONDS=21600
ABS_KEEP_ARTIFACTS=0
ABS_CLIP_WAIT_SECONDS=300

# Local defaults
ABS_OUTPUT_DIR=output
ABS_STATE_FILE=state/seen_challenges.json

# Railway volume-backed state example
# ABS_STATE_FILE=/data/state/seen_challenges.json

# Discord
# ABS_DISCORD_WEBHOOK_URL=

# BlueSky
# ABS_BLUESKY_HANDLE=
# ABS_BLUESKY_APP_PASSWORD=

# X
# ABS_X_API_KEY=
# ABS_X_API_SECRET=
